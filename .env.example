# Backend API URL (required)
# Development: http://localhost:3001
# Production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:3001

# WebSocket URL (optional, defaults to API_URL)
VITE_SOCKET_URL=http://localhost:3001

# Share base URL for QR codes and links (optional, defaults to window.location.origin)
# Development: http://localhost:5173
# Production: https://your-frontend.vercel.app
VITE_SHARE_BASE_URL=http://localhost:5173
